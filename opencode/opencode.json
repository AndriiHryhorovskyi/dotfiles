{
  "$schema": "https://opencode.ai/config.json",
  "model": "zai-coding-plan/glm-4.7",
  "small_model": "opencode/big-pickle",
  "disabled_providers": ["google-vertex", "google-vertex-anthropic"],
  "plugin": ["opencode-gemini-auth@latest"],
  "tui": {
    "scroll_speed": 2
  },
  "theme": "tokyonight",
  "autoupdate": "notify",
  "share": "manual",
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      ".*rc": "deny"
    },
    "bash": {
      "*": "ask",
      "npm run lint": "allow",
      "npm run typecheck": "allow",
      "npm run test*": "allow",
      "npm run *?test*": "allow",
      "npm test": "allow",
      "npm run format": "allow"
    },
    "webfetch": "ask"
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp@latest"],
      "enabled": false
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": false
    }
  },
  "keybinds": {
    "leader": "ctrl+x",
    "app_exit": "<leader>q",
    "model_list": "<leader>m",
    "command_list": "<leader>c",
    "editor_open": "<leader>e",
    "messages_copy": "<leader>y",
    "messages_undo": "<leader>u",
    "messages_redo": "<leader>r",
    "agent_list": "<leader>a",
    "input_clear": "ctrl+c",
    "input_paste": "ctrl+v",
    "input_move_left": "left",
    "input_move_right": "right",
    "input_word_forward": "ctrl+right",
    "input_word_backward": "ctrl+left",
    "input_delete_word_forward": "ctrl+delete",
    "input_delete_word_backward": "ctrl+w,ctrl+backspace",
    "sidebar_toggle": "<leader>b",
    "status_view": "<leader>s",
    "session_timeline": "<leader>g",
    "session_compact": "none",
    "messages_page_up": "pageup,ctrl+b",
    "messages_page_down": "pagedown,ctrl+f",
    "messages_line_up": "ctrl+alt+y",
    "messages_line_down": "ctrl+alt+e",
    "messages_half_page_up": "ctrl+u",
    "messages_half_page_down": "ctrl+d",
    "messages_first": "home",
    "messages_last": "end",
    "messages_toggle_conceal": "none",
    "tips_toggle": "<leader>h"
  }
}
