{
  "$schema": "https://opencode.ai/config.json",
  "tui": {
    "scroll_speed": 2
  },
  "theme": "tokyonight",
  "autoupdate": false,
  "share": "manual",
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "webfetch": "ask"
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp@latest"],
      "enabled": true
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": false
    }
  }
}
