{
  "$schema": "https://opencode.ai/config.json",
  "model": "google/gemini-2.5-pro",
  "small_model": "google/gemini-2.5-flash",
  "disabled_providers": ["google-vertex", "google-vertex-anthropic"],
  "plugin": ["opencode-gemini-auth", "@tarquinen/opencode-dcp@latest"],
  "tui": {
    "scroll_speed": 2
  },
  "theme": "tokyonight",
  "autoupdate": "notify",
  "share": "manual",
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "webfetch": "ask"
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp@latest"],
      "enabled": true
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": false
    }
  },
  "keybinds": {
    "leader": "ctrl+x",
    "app_exit": "<leader>q",
    "editor_open": "<leader>e",
    "messages_copy": "<leader>y",
    "messages_undo": "<leader>u",
    "messages_redo": "<leader>r",
    "agent_list": "<leader>a",
    "input_clear": "ctrl+c",
    "input_paste": "<leader>+p"
  }
}
